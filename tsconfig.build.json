{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "removeComments": false,
    "declarationMap": true,
    "noEmit": false,
    "emitDeclarationOnly": false
  },
  // "include": [
  //   "src/index.ts"
  // ],
  "include": [
    "src/index.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "src/test/**/*",
    "**/*.test.ts",
    "**/*.spec.ts",
    "node_modules",
    "dist",
    "examples/**/*"
  ]
}
